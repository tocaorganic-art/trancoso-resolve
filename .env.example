# Variáveis de ambiente do Trancoso Resolve (copie para .env.local e preencha)

# Base44 SDK
VITE_BASE44_APP_ID=
VITE_BASE44_BACKEND_URL=

# Stripe (chave publicável)
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Maps JavaScript API (restrinja por domínio no Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=
