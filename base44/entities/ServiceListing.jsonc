{
  "name": "ServiceListing",
  "type": "object",
  "properties": {
    "provider_id": {
      "type": "string",
      "description": "ID do prestador de servi\u00e7o"
    },
    "title": {
      "type": "string",
      "description": "T\u00edtulo do servi\u00e7o"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada do que est\u00e1 incluso"
    },
    "not_included": {
      "type": "string",
      "description": "O que n\u00e3o est\u00e1 incluso no servi\u00e7o"
    },
    "category": {
      "type": "string",
      "enum": [
        "Limpeza",
        "Gar\u00e7om",
        "Pedreiro",
        "Jardinagem",
        "Bab\u00e1",
        "Eletricista",
        "Encanador",
        "Pintor",
        "Cozinheiro",
        "Outro"
      ],
      "description": "Categoria do servi\u00e7o"
    },
    "price": {
      "type": "number",
      "description": "Pre\u00e7o do servi\u00e7o"
    },
    "price_unit": {
      "type": "string",
      "enum": [
        "hora",
        "dia",
        "servi\u00e7o",
        "projeto"
      ],
      "default": "hora",
      "description": "Unidade de pre\u00e7o"
    },
    "duration_estimate": {
      "type": "string",
      "description": "Estimativa de dura\u00e7\u00e3o do servi\u00e7o (ex: Aprox. 2 horas)"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs das imagens"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Servi\u00e7o em destaque"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Servi\u00e7o ativo"
    }
  },
  "required": [
    "provider_id",
    "title",
    "category",
    "price"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": true,
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}