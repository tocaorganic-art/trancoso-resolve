{
  "name": "ProviderStripeAccount",
  "type": "object",
  "properties": {
    "provider_id": {
      "type": "string",
      "description": "ID do prestador"
    },
    "stripe_account_id": {
      "type": "string",
      "description": "ID da conta Stripe do prestador"
    },
    "stripe_connect_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Se Stripe Connect est\u00e1 habilitado"
    },
    "onboarding_completed": {
      "type": "boolean",
      "default": false,
      "description": "Se o onboarding foi conclu\u00eddo"
    },
    "charges_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Se cobran\u00e7as est\u00e3o habilitadas"
    },
    "payouts_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Se pagamentos/saques est\u00e3o habilitados"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data de cria\u00e7\u00e3o da conta"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltima atualiza\u00e7\u00e3o da conta"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Notas ou descri\u00e7\u00e3o sobre a conta Stripe"
    }
  },
  "required": [
    "provider_id",
    "stripe_account_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}