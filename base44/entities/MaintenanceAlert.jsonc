{
  "name": "MaintenanceAlert",
  "type": "object",
  "properties": {
    "property_name": {
      "type": "string",
      "description": "Nome da propriedade/villa"
    },
    "equipment": {
      "type": "string",
      "description": "Equipamento ou \u00e1rea"
    },
    "alert_type": {
      "type": "string",
      "enum": [
        "Preditiva",
        "Preventiva",
        "Corretiva",
        "Urgente"
      ],
      "description": "Tipo de alerta"
    },
    "priority": {
      "type": "string",
      "enum": [
        "Baixa",
        "M\u00e9dia",
        "Alta",
        "Cr\u00edtica"
      ],
      "description": "Prioridade"
    },
    "predicted_failure_date": {
      "type": "string",
      "format": "date",
      "description": "Data prevista de falha"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o do problema"
    },
    "ai_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Confian\u00e7a da previs\u00e3o (%)"
    },
    "status": {
      "type": "string",
      "enum": [
        "Aberto",
        "Em Andamento",
        "Resolvido",
        "Adiado"
      ],
      "default": "Aberto",
      "description": "Status do alerta"
    },
    "assigned_to": {
      "type": "string",
      "description": "ID do funcion\u00e1rio respons\u00e1vel"
    },
    "resolution_date": {
      "type": "string",
      "format": "date",
      "description": "Data de resolu\u00e7\u00e3o"
    },
    "cost_estimate": {
      "type": "number",
      "description": "Custo estimado"
    },
    "notes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es"
    }
  },
  "required": [
    "property_name",
    "equipment",
    "alert_type",
    "priority"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.assigned_to": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}