{
  "name": "Employee",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Nome completo do funcion\u00e1rio"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email profissional"
    },
    "phone": {
      "type": "string",
      "description": "Telefone de contato"
    },
    "role": {
      "type": "string",
      "enum": [
        "Gerente",
        "Coordenador",
        "Operacional",
        "Concierge",
        "Suporte"
      ],
      "description": "Fun\u00e7\u00e3o do funcion\u00e1rio"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Habilidades e compet\u00eancias"
    },
    "availability": {
      "type": "string",
      "enum": [
        "Dispon\u00edvel",
        "Ocupado",
        "F\u00e9rias",
        "Licen\u00e7a"
      ],
      "default": "Dispon\u00edvel",
      "description": "Status de disponibilidade"
    },
    "hire_date": {
      "type": "string",
      "format": "date",
      "description": "Data de contrata\u00e7\u00e3o"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Descri\u00e7\u00e3o ou notas adicionais sobre o funcion\u00e1rio"
    }
  },
  "required": [
    "full_name",
    "role"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}