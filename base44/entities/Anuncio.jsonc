{
  "name": "Anuncio",
  "type": "object",
  "properties": {
    "lojista_id": {
      "type": "string",
      "description": "ID do lojista dono do anúncio"
    },
    "titulo": {
      "type": "string",
      "description": "Título do anúncio"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição do anúncio"
    },
    "imagem_url": {
      "type": "string",
      "description": "URL da imagem do anúncio"
    },
    "cta_label": {
      "type": "string",
      "description": "Texto do botão de call-to-action"
    },
    "cta_url": {
      "type": "string",
      "description": "URL de destino do call-to-action"
    },
    "categoria": {
      "type": "string",
      "description": "Categoria do anúncio"
    },
    "destino": {
      "type": "string",
      "description": "Destino relacionado ao anúncio (ex: Trancoso, Arraial d'Ajuda)"
    },
    "ativo": {
      "type": "boolean",
      "default": true,
      "description": "Se o anúncio está ativo e visível na plataforma"
    },
    "plano": {
      "type": "string",
      "enum": [
        "basico",
        "destaque",
        "premium"
      ],
      "description": "Plano de veiculação do anúncio"
    },
    "impressoes": {
      "type": "number",
      "default": 0,
      "description": "Número de impressões do anúncio"
    },
    "cliques": {
      "type": "number",
      "default": 0,
      "description": "Número de cliques no CTA do anúncio"
    },
    "data_inicio": {
      "type": "string",
      "format": "date",
      "description": "Data de início da veiculação"
    },
    "data_fim": {
      "type": "string",
      "format": "date",
      "description": "Data de término da veiculação"
    }
  },
  "required": [
    "lojista_id",
    "titulo"
  ],
  "rls": {
    "read": true,
    "create": true,
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}
