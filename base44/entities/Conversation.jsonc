{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "userId": {
      "type": "string",
      "description": "ID do usu\u00e1rio dono da conversa."
    },
    "userName": {
      "type": "string",
      "description": "Nome do usu\u00e1rio."
    },
    "agentType": {
      "type": "string",
      "default": "toca",
      "description": "Tipo de agente (para futuras expans\u00f5es)."
    },
    "lastMessage": {
      "type": "string",
      "description": "Preview da \u00faltima mensagem."
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Descri\u00e7\u00e3o ou notas sobre a conversa"
    }
  },
  "required": [
    "userId"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}