{
  "name": "ChatConversation",
  "type": "object",
  "properties": {
    "participant_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs dos participantes da conversa"
    },
    "subject": {
      "type": "string",
      "description": "Assunto da conversa"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time",
      "description": "Data da \u00faltima mensagem"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Se a conversa est\u00e1 ativa"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Descri\u00e7\u00e3o ou notas sobre a conversa"
    }
  },
  "required": [
    "participant_ids"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.participant_ids": {
            "$in": [
              "{{user.email}}"
            ]
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.participant_ids": {
            "$in": [
              "{{user.email}}"
            ]
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.participant_ids": {
            "$in": [
              "{{user.email}}"
            ]
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}