{
  "name": "ServiceRequest",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "ID do usu\u00e1rio cliente que solicitou"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "client_phone": {
      "type": "string",
      "description": "Telefone do cliente"
    },
    "client_email": {
      "type": "string",
      "format": "email"
    },
    "service_id": {
      "type": "string",
      "description": "ID do servi\u00e7o solicitado"
    },
    "provider_id": {
      "type": "string",
      "description": "ID do prestador"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data desejada para o servi\u00e7o"
    },
    "time": {
      "type": "string",
      "description": "Hor\u00e1rio desejado"
    },
    "location": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "complement": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        }
      },
      "description": "Detalhes da localiza\u00e7\u00e3o do servi\u00e7o"
    },
    "message": {
      "type": "string",
      "description": "Mensagem/detalhes adicionais"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pendente",
        "Confirmado",
        "Em Andamento",
        "Conclu\u00eddo",
        "Cancelado",
        "Rejeitado"
      ],
      "default": "Pendente"
    },
    "urgency": {
      "type": "string",
      "enum": [
        "Normal",
        "Urgente"
      ],
      "default": "Normal"
    },
    "provider_response": {
      "type": "string",
      "description": "Resposta ou justificativa do prestador em caso de rejei\u00e7\u00e3o"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Descri\u00e7\u00e3o detalhada da solicita\u00e7\u00e3o"
    }
  },
  "required": [
    "client_name",
    "client_phone",
    "service_id",
    "provider_id",
    "date"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.client_email": "{{user.email}}"
        },
        {
          "data.provider_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.provider_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}